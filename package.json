{
  "name": "shopify-business-app",
  "version": "0.1.0",
  "private": true,
  "description": "Custom Shopify app starter with business-specific rules and webhook automation.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && npm run copy:runtime-assets",
    "copy:runtime-assets": "mkdir -p dist/frontend && cp -R frontend/blueprint-v2 dist/frontend/ && cp system-blueprint.json dist/system-blueprint.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "seed:whatsapp": "tsx src/db/seed/seedWhatsappLeads.ts",
    "backfill:whatsapp-history": "tsx src/db/seed/backfillWhatsAppHistory.ts",
    "backfill:conversion-score": "tsx src/scripts/backfillConversionScores.ts",
    "backfill:ticket-value": "tsx src/scripts/backfillTicketValues.ts",
    "simulate:quote-approval": "tsx src/scripts/simulateQuoteApproval.ts",
    "test:zoko-quote-send": "tsx src/scripts/testZokoQuoteSend.ts",
    "test:zoko-quote-template": "tsx src/scripts/testZokoQuoteTemplateSend.ts",
    "test:price-extraction": "tsx --test src/services/priceExtraction.test.ts",
    "test:forecast-simulation": "tsx --test src/services/forecastSimulation.test.ts",
    "test:shopify-payments": "tsx --test src/services/shopifyOrderPayments.test.ts",
    "test:ticket-value-inference": "tsx --test src/services/ticketValueInference.test.ts"
  },
  "dependencies": {
    "@google-cloud/bigquery": "^8.2.0",
    "@shopify/shopify-api": "^11.14.1",
    "@types/pdfkit": "^0.17.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "framer-motion": "^12.34.3",
    "google-trends-api": "^4.9.2",
    "googleapis": "^171.4.0",
    "pdfkit": "^0.17.2",
    "pg": "^8.18.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^4.17.23",
    "@types/node": "^24.3.1",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
