PORT=3000
NODE_ENV=development

# Shopify app credentials (from Shopify Partners dashboard)
SHOPIFY_API_KEY=replace_me
SHOPIFY_API_SECRET=replace_me
SHOPIFY_SCOPES=read_products,write_products,read_orders,read_customers,write_customers,read_locations
SHOPIFY_APP_URL=https://replace-with-your-tunnel-url.ngrok-free.app
DATABASE_URL=postgres://user:password@localhost:5432/shopify_business_app
# Cloud SQL helper: set false only if local TLS verification fails
DB_SSL_REJECT_UNAUTHORIZED=true
GCP_PROJECT_ID=
BIGQUERY_DATASET=analytics
BIGQUERY_LOCATION=US
BIGQUERY_REVENUE_MODEL_NAME=revenue_forecast_model
BIGQUERY_SALES_TABLE_NAME=sales_daily
FORECAST_REFERENCE_ORDER_VALUE_MAD=35000
FORECAST_RARE_MONTH_CAP_MAD=1400000
FORECAST_RARE_MONTH_MAX_REPEAT=2
GOOGLE_APPLICATION_CREDENTIALS=
GSC_SITE_URL=
TRENDS_KEYWORDS=
TRENDS_GEO=MA
GA4_PROPERTY_ID=

# Default shop domain for testing (optional)
SHOPIFY_SHOP=your-store.myshopify.com

# Admin API access token (needed for dashboard order sync)
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_replace_me

# Optional legacy fallback (if your app still uses refresh token flow)
SHOPIFY_REFRESH_TOKEN=replace_me
SPLINE_SCENE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001
ENABLE_TEAM_QUOTE_APPROVAL=false
ENABLE_TEAM_QUOTE_ANALYTICS=true
ALLOW_TEAM_SAME_AS_LEAD_FOR_TEST=false
WHATSAPP_TEAM_NUMBER=
WHATSAPP_AI_PROMPTS_JSON=
WHATSAPP_AI_AUTO_ANALYZE=true

# WhatsApp API template (Zoko)
ZOKO_API_URL=https://chat.zoko.io/v2/message
ZOKO_HISTORY_API_URL=
ZOKO_HISTORY_SYNC_ON_STARTUP=true
ZOKO_HISTORY_SYNC_INTERVAL_MINUTES=10
ZOKO_HISTORY_SYNC_MAX_PAGES=40
ZOKO_WEBHOOK_TOKEN=replace_with_shared_secret
ZOKO_AUTH_TOKEN=replace_me
ZOKO_AUTH_HEADER=apikey
ZOKO_AUTH_PREFIX=
ZOKO_TEMPLATE_NAME=invoice_notification
ZOKO_TEMPLATE_LANGUAGE=fr
TEAM_QUOTE_TEMPLATE_NAME=
ZOKO_TEAM_QUOTE_TEMPLATE_NAME=
TEAM_QUOTE_TEMPLATE_LANG=fr
APPROVED_QUOTE_TEMPLATE_NAME=
ZOKO_TEMPLATE_TYPE=richTemplate
ZOKO_TEMPLATE_ARGS_JSON=
ZOKO_CHANNEL=whatsapp
ZOKO_REVIEW_TEMPLATE_NAME=demander_avis
ZOKO_REVIEW_TEMPLATE_LANGUAGE=fr
ZOKO_REVIEW_TEMPLATE_TYPE=buttonTemplate
ZOKO_REVIEW_TEMPLATE_ARGS_JSON=
ZOKO_REVIEW_TEMPLATE_PAYLOAD_JSON=
ZOKO_APPOINTMENT_TEMPLATE_LANGUAGE=fr
ZOKO_APPOINTMENT_TEMPLATE_TYPE=buttonTemplate
ZOKO_APPOINTMENT_TEMPLATE_ARGS_JSON=
ZOKO_APPOINTMENT_TEMPLATE_PAYLOAD_JSON=
ZOKO_APPOINTMENT_CONFIRM_TEMPLATE_NAME=
ZOKO_APPOINTMENT_REMINDER_TEMPLATE_NAME=
ZOKO_APPOINTMENT_DESIGNER_REMINDER_TEMPLATE_NAME=
ZOKO_APPOINTMENT_DESIGNER_REMINDER_LANGUAGE=French
ZOKO_APPOINTMENT_DESIGNER_REMINDER_PHONE=
ZOKO_APPOINTMENT_RESCHEDULE_TEMPLATE_NAME=
ZOKO_APPOINTMENT_CANCEL_TEMPLATE_NAME=
SHOPIFY_APPOINTMENTS_METAFIELD_NAMESPACE=custom
SHOPIFY_APPOINTMENTS_METAFIELD_KEY=appointments
# Temporary workaround only if provider TLS chain fails from your machine
ZOKO_ALLOW_INSECURE_TLS=false
# Optional custom JSON payload with placeholders:
# {{phone}}, {{customer_name}}, {{order_name}}, {{invoice_url}}, {{total_amount}}, {{outstanding_amount}}, {{currency}}
ZOKO_TEMPLATE_PAYLOAD_JSON=
